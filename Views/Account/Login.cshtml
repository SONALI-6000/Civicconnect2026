@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Login - CivicConnect</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        body {
            background: linear-gradient(to right, #141e30, #243b55);
            height: 100vh;
        }

        .login-card {
            width: 350px;
            border-radius: 15px;
        }
    </style>
</head>

<body class="d-flex justify-content-center align-items-center">

    <div class="card login-card shadow p-4">

        <h3 class="text-center mb-3">CivicConnect 🚀</h3>

        <!-- ✅ Success -->
        @if (TempData["LoginSuccess"] != null)
        {
            <div class="alert alert-success text-center">
                @TempData["LoginSuccess"]
            </div>
        }

        <!-- ❌ Error -->
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger text-center">
                @TempData["Error"]
            </div>
        }

        <form method="post">

            <input name="email" class="form-control mb-3" placeholder="Email" />

            <input name="password" type="password" class="form-control mb-3" placeholder="Password" />

            <button class="btn btn-primary w-100">Login</button>

        </form>

        <p class="text-center mt-3">
            Don't have an account?
            <a href="/Account/Register">Register</a>
        </p>

    </div>

</body>
</html>