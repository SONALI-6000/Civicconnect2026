@{
    ViewData["Title"] = "Dashboard";
}

<!-- 🔥 HERO SECTION -->
<div class="hero-section text-center text-white">

    <h1 class="fw-bold display-5">Smart Civic Reporting System</h1>
    <p>Report issues • Track progress • Earn rewards</p>

</div>

<div class="container mt-5">

    <!-- 🔥 Logout -->
    <div class="d-flex justify-content-end mb-3">
        <a href="/Account/Logout" class="btn btn-danger">Logout</a>
    </div>

    <!-- 🔥 CARDS -->
    <div class="row text-center">

        <!-- Report -->
        <div class="col-md-4 d-flex">
            <div class="card custom-card w-100 p-3">
                <img src="https://cdn-icons-png.flaticon.com/512/854/854878.png"
                     width="60" class="mx-auto mt-2" />
                <h5 class="mt-3">Report Issue</h5>
                <p>Raise civic complaints easily</p>
                <a href="/User/CreateComplaint" class="btn btn-primary mt-auto">Report</a>
            </div>
        </div>

        <!-- My Complaints -->
        <div class="col-md-4 d-flex">
            <div class="card custom-card w-100 p-3">
                <img src="https://cdn-icons-png.flaticon.com/512/1828/1828919.png"
                     width="60" class="mx-auto mt-2" />
                <h5 class="mt-3">My Complaints</h5>
                <p>Track your submitted issues</p>
                <a href="/User/MyComplaints" class="btn btn-success mt-auto">View</a>
            </div>
        </div>

        <!-- Rewards -->
        <div class="col-md-4 d-flex">
            <div class="card custom-card w-100 p-3">
                <img src="https://cdn-icons-png.flaticon.com/512/190/190411.png"
                     width="60" class="mx-auto mt-2" />
                <h5 class="mt-3">Rewards</h5>
                <p>Earn points for reporting issues</p>
                <a href="/User/Rewards" class="btn btn-warning mt-auto">Check</a>
            </div>
        </div>

    </div>

</div>