@model CivicConnect.Models.Complaint

<div class="container mt-5">
    <h2>Report Issue</h2>

    <form method="post" enctype="multipart/form-data">

        <!-- Issue Type -->
        <select asp-for="Title" class="form-control mb-2">
            <option value="">-- Select Issue Type --</option>
            <option value="Garbage">Garbage</option>
            <option value="Pothole">Pothole</option>
            <option value="Water Leakage">Water Leakage</option>
            <option value="Street Light Issue">Street Light Issue</option>
            <option value="Drainage Problem">Drainage Problem</option>
        </select>

        <!-- Description -->
        <textarea asp-for="Description" class="form-control mb-2" placeholder="Description"></textarea>

        <!-- Map -->
        <iframe id="mapFrame" width="100%" height="300" style="border:0;"></iframe>

        <!-- Hidden lat/lng -->
        <input type="hidden" id="lat" name="Latitude" />
        <input type="hidden" id="lng" name="Longitude" />

        <!-- Location input -->
        <input id="locationInput" name="Location" class="form-control mb-2"
               placeholder="Enter location (e.g. MP Nagar, Bhopal)" autocomplete="off" />

        <!-- Suggestions -->
        <ul id="suggestions" class="list-group mb-2"></ul>

        <!-- Button -->
        <button type="button" onclick="getLocation()" class="btn btn-info mb-2">
            Get Live Location 📍
        </button>

        <!-- Image -->
        <input type="file" name="image" class="form-control mb-3" />

        <button class="btn btn-primary">Submit</button>
    </form>
</div>

<script>
    // 🔥 SINGLE getLocation (with address)
    async function getLocation() {
        if (navigator.geolocation) {

            navigator.geolocation.getCurrentPosition(async function (position) {

                let lat = position.coords.latitude;
                let lng = position.coords.longitude;

                document.getElementById("lat").value = lat;
                document.getElementById("lng").value = lng;

                // 🔥 Reverse geocoding (address)
                let response = await fetch(
                    `https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lng}&format=json`
                );

                let data = await response.json();

                let address = data.display_name;

                document.getElementById("locationInput").value = address;

                // Map update
                document.getElementById("mapFrame").src =
                    "https://maps.google.com/maps?q=" + lat + "," + lng + "&z=15&output=embed";

            }, function () {
                alert("Location permission denied!");
            });

        } else {
            alert("Geolocation not supported");
        }
    }

    // 🔥 Smart suggestions
    const locations = [
        "MP Nagar, Bhopal",
        "New Market, Bhopal",
        "Habibganj, Bhopal",
        "Kolar Road, Bhopal",
        "Arera Colony, Bhopal",
        "Bairagarh, Bhopal",
        "Ayodhya Nagar, Bhopal"
    ];

    const input = document.getElementById("locationInput");
    const list = document.getElementById("suggestions");

    input.addEventListener("input", function () {
        let value = this.value.toLowerCase();
        list.innerHTML = "";

        if (value === "") return;

        let filtered = locations.filter(loc => loc.toLowerCase().includes(value));

        filtered.forEach(loc => {
            let li = document.createElement("li");
            li.className = "list-group-item list-group-item-action";
            li.textContent = loc;

            li.onclick = function () {
                input.value = loc;
                list.innerHTML = "";
            };

            list.appendChild(li);
        });
    });
</script>